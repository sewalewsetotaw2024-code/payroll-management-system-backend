{
  "info": {
    "name": "Payroll Management System API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Complete API collection for the Payroll Management System. All configuration and integration endpoints under /api/v1.\n\nPath parameters like :id and :salaryStructureId are Postman path variables — fill them in before sending the request."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1", "type": "string" },
    { "key": "authBaseUrl", "value": "http://localhost:5000/api/v1", "type": "string" },
    { "key": "token", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{token}}", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:3000/health",
              "host": ["http://localhost:3000"],
              "path": ["health"]
            }
          }
        }
      ]
    },
    {
      "name": "Auth (Login here first)",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "const token = json.token || json.data?.token || json.accessToken || json.data?.accessToken;",
                  "if (token) {",
                  "  pm.collectionVariables.set('token', token);",
                  "  console.log('Token saved to collection variables');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@company.com\",\n  \"password\": \"your-password\"\n}"
            },
            "url": {
              "raw": "{{authBaseUrl}}/auth/login",
              "host": ["{{authBaseUrl}}"],
              "path": ["auth", "login"]
            }
          },
          "description": "Login against the Auth Service. The returned JWT is automatically saved to the collection variable and used for all subsequent requests."
        }
      ]
    },

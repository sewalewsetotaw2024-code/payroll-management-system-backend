model PayrollBatch {
  id              String                 @id @default(uuid())
  name            String
  payrollPeriodId String
  status          BatchStatus            @default(DRAFT)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  payrollPeriod   PayrollPeriod          @relation(fields: [payrollPeriodId], references: [id])
  payrollRuns     PayrollRun[]
  employees       PayrollBatchEmployee[]

  @@index([payrollPeriodId])
}

model PayrollBatchEmployee {
  id              String       @id @default(uuid())
  employeeId      String
  payrollBatchId  String
  payrollPeriodId String

  employee        Employee     @relation(fields: [employeeId], references: [id])
  payrollBatch    PayrollBatch @relation(fields: [payrollBatchId], references: [id], onDelete: Cascade)
  payrollPeriod   PayrollPeriod @relation(fields: [payrollPeriodId], references: [id])

  @@index([payrollBatchId])
  @@index([payrollPeriodId])
  @@unique([employeeId, payrollPeriodId])
}

/// Unified in-app notification model — replaces separate PayrollNotification
/// and AttendanceNotification tables.  Stores all notification types
/// (payroll, attendance, payslip, system) in one table with a generic
/// referenceId for linking to the source entity.
model AppNotification {
  id          String   @id @default(uuid())
  recipientId Int
  type        String                       // e.g. PAYROLL_SUBMITTED, ATTENDANCE_APPROVED, PAYSLIP_GENERATED
  title       String
  message     String?
  category    String   @default("general")  // payroll, attendance, payslip, system
  read        Boolean  @default(false)
  referenceId String?                      // generic FK — payrollRunId, attendanceImportId, etc.
  link        String?                      // frontend deep-link (e.g. "/payroll", "/approval")
  createdAt   DateTime @default(now())

  @@index([recipientId, read])
  @@index([recipientId, createdAt])
}

model StatutoryReport {
  id              String           @id @default(uuid())
  companyId       Int
  reportType      ReportType
  payrollPeriodId String?
  format          ExportFormat
  filePath        String?
  submittedAt     DateTime?
  submittedBy     String?
  status          ProcessingStatus @default(GENERATED)
  createdAt       DateTime         @default(now())
  company         Company          @relation(fields: [companyId], references: [id])
  payrollPeriod   PayrollPeriod?   @relation(fields: [payrollPeriodId], references: [id])
}

model ImportFolder {
  id          String         @id @default(uuid())
  name        String
  companyId   Int
  parentId    String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  attachments Attachment[]
  parent      ImportFolder?  @relation("FolderChildren", fields: [parentId], references: [id])
  children    ImportFolder[] @relation("FolderChildren")

  @@index([companyId])
  @@index([parentId])
}


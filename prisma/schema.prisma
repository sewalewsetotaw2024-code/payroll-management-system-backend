/// PayrollLeaveItem — Per-leave-type breakdown within a payroll run item.
///
/// Stores the period-accurate leave days (with half-day support) for each
/// leave type per employee per payroll run.  This is populated by the
/// LeavePeriodService which queries the external Employee Module DB
/// directly using the period-accurate SQL pattern.
///
/// Unpaid leave days generate a deduction (dailyRate × leaveDays).
/// Paid leave days are factored into taxable income calculations.
model PayrollLeaveItem {
  id                String         @id @default(uuid())
  payrollRunItemId  String
  employeeId        String
  companyId         Int
  payrollPeriodId   String?
  leaveType         String
  leaveCode         String?
  leaveDaysInPeriod Decimal        @db.Decimal(7, 2)
  isPaid            Boolean        @default(false)
  deductionAmount   Decimal        @db.Decimal(15, 2)
  syncedAt          DateTime       @default(now())
  company           Company        @relation(fields: [companyId], references: [id])
  employee          Employee       @relation(fields: [employeeId], references: [id])
  payrollPeriod     PayrollPeriod? @relation(fields: [payrollPeriodId], references: [id])
  payrollRunItem    PayrollRunItem @relation(fields: [payrollRunItemId], references: [id])

  @@unique([payrollRunItemId, leaveType])
  @@index([employeeId])
  @@index([payrollRunItemId])
}


generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                   Int                   @id
  name                 String
  code                 String?
  isActive             Boolean               @default(true)
  syncedAt             DateTime              @default(now())
  actingAllowanceRules ActingAllowanceRule[]
  actingAssignments    ActingAssignment[]
  allowanceConfigs     AllowanceConfig[]
  approvalWorkflows    ApprovalWorkflow[]
  archiveBatches       ArchiveBatch[]
  bankAccounts         BankAccount[]
  bonusRules           BonusRule[]
  branches             Branch[]
  complianceRules      ComplianceRule[]
  configurations       Configuration[]
  costSharingRules     CostSharingRule[]
  departments          Department[]
  employees            Employee[]
  employeeDeductions   EmployeeDeduction[]
  fiscalYears          FiscalYear[]
  jobGrades            JobGrade[]
  leaveApplications    LeaveApplication[]
  leaveBalances        LeaveBalance[]
  leaveDeductions      LeaveDeduction[]
  manualAdjustments    ManualAdjustment[]
  overtimeRules        OvertimeRule[]
  payFrequencies            PayFrequency[]
  payslipNotificationSettings PayslipNotificationSettings?
  payrollLeaveItems          PayrollLeaveItem[]
  payrollPeriods       PayrollPeriod[]
  payslipTemplates     PayslipTemplate[]
  pensionRules         PensionRule[]
  positions            Position[]
  reportTemplates      ReportTemplate[]
  salaryHistories      SalaryHistory[]
  salaryStructures     SalaryStructure[]
  statutoryReports     StatutoryReport[]
  taxBrackets          TaxBracket[]
  workUnits            WorkUnit[]
  currencies           SystemCurrency[]
  currencyRates        CurrencyRate[]
  baseCurrencyId       String?               @unique // FK to SystemCurrency.id for the company's base currency
  baseCurrency         SystemCurrency?       @relation("BaseCurrency", fields: [baseCurrencyId], references: [id])
}

model Employee {
  id                 String                     @id @default(uuid())
  externalId         String?                    @unique
  companyId          Int
  userId             Int?
  firstName          String
  lastName           String
  email              String?
  tinNumber          String?
  jobPosition        String?
  hireDate           DateTime?
  termDate           DateTime?
  status             EmployeeStatus             @default(ACTIVE)
  currency           Currency                   @default(ETB)
  branchId           String?
  departmentId       Int?
  workUnitId         String?
  positionId         String?
  jobGradeId         String?
  managerName        String?
  metadata           Json?
  syncedAt           DateTime                   @default(now())
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  actingAssignments       ActingAssignment[] @relation("ActingEmployee")
  replacedActingAssignments ActingAssignment[] @relation("ReplacedEmployee")
  monthlySummaries          AttendanceMonthlySummary[]
  attendanceRecords  AttendanceRecord[]
  bankAccounts       BankAccount[]
  branch             Branch?                    @relation(fields: [branchId], references: [id])
  company            Company                    @relation(fields: [companyId], references: [id])
  department         Department?                @relation(fields: [departmentId], references: [id])
  jobGrade           JobGrade?                  @relation(fields: [jobGradeId], references: [id])
  position           Position?                  @relation(fields: [positionId], references: [id])
  workUnit           WorkUnit?                  @relation(fields: [workUnitId], references: [id])
  allowances         EmployeeAllowance[]
  compensation       EmployeeCompensation?
  employeeDeductions EmployeeDeduction[]
  profile            EmployeeProfile?
  employeeSyncLogs   EmployeeSyncLog[]
  exceptionLogs      ExceptionLog[]
  leaveApplications  LeaveApplication[]
  leaveBalances      LeaveBalance[]
  leaveDeductions    LeaveDeduction[]
  manualAdjustments  ManualAdjustment[]
  payrollLeaveItems        PayrollLeaveItem[]
  payrollRunItems          PayrollRunItem[]
  salaryHistories          SalaryHistory[]
  attendancePeriodSummaries AttendancePeriodSummary[]
  batchAssignments           PayrollBatchEmployee[]

  @@index([companyId, status])
  @@index([externalId])
}

model EmployeeProfile {
  id                String    @id @default(uuid())
  employeeId        String    @unique
  gender            String?
  dateOfBirth       DateTime?
  employmentType    String?
  probationEndDate  DateTime?
  employmentEndDate DateTime?
  placeOfWork       String?
  contractReference String?
  syncedAt          DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  employee          Employee  @relation(fields: [employeeId], references: [id])
}

model EmployeeCompensation {
  id          String   @id @default(uuid())
  employeeId  String   @unique
  basicSalary Decimal? @db.Decimal(15, 2)
  grossSalary Decimal? @db.Decimal(15, 2)
  taxablePay  Decimal? @db.Decimal(15, 2)
  csBalance   Decimal? @db.Decimal(15, 2)
  pensionElig Boolean  @default(true)
  taxExempt   Boolean  @default(false)
  pensionNo   String?
  syncedAt    DateTime @default(now())
  updatedAt   DateTime @updatedAt
  employee    Employee @relation(fields: [employeeId], references: [id])
}

model EmployeeAllowance {
  id            String        @id @default(uuid())
  employeeId    String
  allowanceType AllowanceType
  amount        Decimal       @db.Decimal(15, 2)
  isActive      Boolean       @default(true)
  syncedAt      DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  employee      Employee      @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, allowanceType])
  @@index([employeeId, isActive])
}

model AppUser {
  id              Int              @id
  email           String?
  roleId          Int?
  status          UserStatus       @default(ACTIVE)
  syncedAt        DateTime         @default(now())
  role            AppRole?         @relation(fields: [roleId], references: [id])
  approvalActions ApprovalAction[]
}

model AppRole {
  id                   Int            @id
  name                 String
  permissions          Json?
  syncedAt             DateTime       @default(now())
  users                AppUser[]
  approvalSteps        ApprovalStep[] @relation("RequiredRole")
  alternateApprovalSteps ApprovalStep[] @relation("AlternateRole")
}

model Bank {
  id             Int             @id
  name           String
  code           String?
  isActive       Boolean         @default(true)
  syncedAt       DateTime        @default(now())
  bankAccounts   BankAccount[]
  bankExportJobs BankExportJob[]
  paymentFiles   PaymentFile[]
}

model Branch {
  id        String     @id @default(uuid())
  companyId Int
  name      String
  location  String?
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  company   Company    @relation(fields: [companyId], references: [id])
  employees Employee[]
}

model WorkUnit {
  id           String      @id @default(uuid())
  companyId    Int
  departmentId Int?
  name         String
  code         String?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  employees    Employee[]
  company      Company     @relation(fields: [companyId], references: [id])
  department   Department? @relation(fields: [departmentId], references: [id])
}

model Position {
  id                String             @id @default(uuid())
  companyId         Int
  title             String
  code              String?
  jobGradeId        String?
  basicSalary       Decimal?           @db.Decimal(15, 2)
  grossSalary       Decimal?           @db.Decimal(15, 2)
  currency          Currency           @default(ETB)
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  actingAssignments ActingAssignment[] @relation("ActingPosition")
  employees         Employee[]
  company           Company            @relation(fields: [companyId], references: [id])
  jobGrade          JobGrade?          @relation(fields: [jobGradeId], references: [id])
}

model JobGrade {
  id        String     @id @default(uuid())
  companyId Int
  name      String
  code      String?
  level     Int
  minSalary Decimal?   @db.Decimal(15, 2)
  maxSalary Decimal?   @db.Decimal(15, 2)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  employees Employee[]
  company   Company    @relation(fields: [companyId], references: [id])
  positions Position[]
}

model Department {
  id        Int        @id
  companyId Int
  name      String
  code      String?
  isActive  Boolean    @default(true)
  syncedAt  DateTime   @default(now())
  company   Company    @relation(fields: [companyId], references: [id])
  employees Employee[]
  workUnits WorkUnit[]
}

model SalaryHistory {
  id            String    @id @default(uuid())
  employeeId    String
  companyId     Int
  basicSalary   Decimal   @db.Decimal(15, 2)
  currency      Currency
  effectiveDate DateTime
  endDate       DateTime?
  reason        String?
  createdAt     DateTime  @default(now())
  company       Company   @relation(fields: [companyId], references: [id])
  employee      Employee  @relation(fields: [employeeId], references: [id])

  @@index([employeeId, effectiveDate])
}

model TaxBracket {
  id              String    @id @default(uuid())
  companyId       Int
  lowerBound      Decimal   @db.Decimal(15, 2)
  upperBound      Decimal?  @db.Decimal(15, 2)
  rate            Decimal   @db.Decimal(5, 4)
  deductionAmount Decimal   @db.Decimal(15, 2)
  effectiveDate   DateTime
  expiryDate      DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  company         Company   @relation(fields: [companyId], references: [id])

  @@index([companyId, isActive])
  @@index([companyId, effectiveDate])
}

model PensionRule {
  id                     String       @id @default(uuid())
  companyId              Int
  employeeRate           Decimal      @default(0.0700) @db.Decimal(5, 4)
  employerRate           Decimal      @default(0.1100) @db.Decimal(5, 4)
  basis                  PensionBasis @default(BASIC)
  applyMaxCap            Boolean      @default(false)
  maxCapAmount           Decimal?     @db.Decimal(15, 2)
  mandatoryForForeigners Boolean      @default(false)
  remittanceDeadlineDays Int          @default(30)
  effectiveDate          DateTime
  isActive               Boolean      @default(true)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  company                Company      @relation(fields: [companyId], references: [id])

  @@unique([companyId, basis, effectiveDate])
  @@index([companyId, isActive])
}

model AllowanceConfig {
  id           String      @id @default(uuid())
  companyId    Int
  earningType  String      @db.VarChar(100)
  label        String
  isTaxable    Boolean     @default(true)
  isExempt     Boolean     @default(false)
  exemptPercent Decimal?   @db.Decimal(5, 4)
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  company      Company     @relation(fields: [companyId], references: [id])

  @@unique([companyId, earningType])
  @@index([companyId, isActive])
}

model CostSharingRule {
  id            String       @id @default(uuid())
  companyId     Int
  rate          Decimal      @default(0.1000) @db.Decimal(5, 4)
  basis         PensionBasis @default(BASIC)
  effectiveDate DateTime
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  company       Company      @relation(fields: [companyId], references: [id])
}

model OvertimeRule {
  id               String           @id @default(uuid())
  companyId        Int
  category         OvertimeCategory
  rate             Decimal          @db.Decimal(5, 2)
  calculationBase  PensionBasis     @default(BASIC)
  isTaxable        Boolean          @default(true)
  weeklyCapHours   Decimal          @default(12) @db.Decimal(5, 2)
  monthlyCapHours  Decimal?         @db.Decimal(5, 2)
  effectiveDate    DateTime
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  company          Company          @relation(fields: [companyId], references: [id])

  @@unique([companyId, category, effectiveDate])
}

model BonusRule {
  id                  String                     @id @default(uuid())
  companyId           Int
  name                String
  description         String?
  cycle               BonusCycle
  calculationType     BonusCalculationType
  taxationType        TaxationType               @default(TAXABLE)
  taxWaiverPercent    Decimal?                   @db.Decimal(5, 4)
  effectiveDate       DateTime
  expiryDate          DateTime?
  isActive            Boolean                    @default(true)
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  eligibilityCriteria BonusEligibilityCriteria[]
  bonusMappings       BonusMapping[]
  company             Company                    @relation(fields: [companyId], references: [id])
  payrollBonuses      PayrollBonus[]
}

model BonusEligibilityCriteria {
  id          String               @id @default(uuid())
  bonusRuleId String
  parameter   EligibilityParameter
  operator    String
  value       String
  logicGroup  LogicOperator        @default(AND)
  groupOrder  Int                  @default(0)
  createdAt   DateTime             @default(now())
  bonusRule   BonusRule            @relation(fields: [bonusRuleId], references: [id])
}

model BonusMapping {
  id                   String    @id @default(uuid())
  bonusRuleId          String
  conditionDescription String?
  bonusAmount          Decimal?  @db.Decimal(15, 2)
  bonusPercent         Decimal?  @db.Decimal(5, 4)
  createdAt            DateTime  @default(now())
  bonusRule            BonusRule @relation(fields: [bonusRuleId], references: [id])
}

model ActingAllowanceRule {
  id                  String               @id @default(uuid())
  companyId           Int
  calculationMethod   CalculationMethod    @default(PERCENTAGE)
  fixedAmount         Decimal?             @db.Decimal(15, 2)
  minimumPeriodMonths Int                  @default(1)
  maximumPeriodMonths Int                  @default(6)
  basis               ActingAllowanceBasis @default(BASIC_DIFF)
  payablePercent      Decimal              @default(1.0000) @db.Decimal(5, 4)
  /// JSON array of `{ startMonth, endMonth, percent }` for multi-month percentage rules
  tiers               Json?                @default("[]")
  effectiveDate       DateTime
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  company             Company              @relation(fields: [companyId], references: [id])
  actingAssignments   ActingAssignment[]
}

model SalaryStructure {
  id             String          @id @default(uuid())
  companyId      Int
  name           String
  description    String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deductionItems DeductionItem[]
  earningsItems  EarningsItem[]
  company        Company         @relation(fields: [companyId], references: [id])
}

model EarningsItem {
  id                String          @id @default(uuid())
  salaryStructureId String
  earningType       EarningType
  label             String
  isTaxable         Boolean         @default(true)
  isConfigurable    Boolean         @default(true)
  defaultAmount     Decimal?        @db.Decimal(15, 2)
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  salaryStructure   SalaryStructure @relation(fields: [salaryStructureId], references: [id])
}

model DeductionItem {
  id                String                    @id @default(uuid())
  salaryStructureId String
  deductionType     DeductionType
  label             String
  isMandatory       Boolean                   @default(false)
  isStatutory       Boolean                   @default(false)
  isActive          Boolean                   @default(true)
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  amount            Decimal?                  @db.Decimal(15, 2)
  calculationType   DeductionCalculationType?
  calculationBasis  CalculationBasis?
  percent           Decimal?                  @db.Decimal(6, 2)
  salaryStructure   SalaryStructure           @relation(fields: [salaryStructureId], references: [id])

  @@index([salaryStructureId, isActive])
}

model EmployeeDeduction {
  id                String                   @id @default(uuid())
  employeeId        String
  deductionItemId   String?
  deductionType     DeductionType
  label             String
  calculationType   DeductionCalculationType
  amount            Decimal?                 @db.Decimal(15, 2)
  percent           Decimal?                 @db.Decimal(6, 2)
  status            EmployeeDeductionStatus  @default(ACTIVE)
  startDate         DateTime?
  endDate           DateTime?
  effectivePeriodId String?
  description       String?
  refNo             String?
  prorated          Boolean                  @default(false)
  priority          Int                      @default(0)
  isActive          Boolean                  @default(true)
  companyId         Int
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  paymentPlan       DeductionPaymentPlan?
  company           Company                  @relation(fields: [companyId], references: [id])
  employee          Employee                 @relation(fields: [employeeId], references: [id])

  @@index([employeeId, status])
  @@index([employeeId, isActive])
  @@index([companyId, status])
}

model DeductionPaymentPlan {
  id                  String            @id @default(uuid())
  employeeDeductionId String            @unique
  totalAmount         Decimal?          @db.Decimal(15, 2)
  paidAmount          Decimal           @default(0) @db.Decimal(15, 2)
  remaining           Decimal?          @db.Decimal(15, 2)
  numInstallments     Int?
  paidInstallments    Int               @default(0)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  employeeDeduction   EmployeeDeduction @relation(fields: [employeeDeductionId], references: [id])
}

model Configuration {
  id        String   @id @default(uuid())
  companyId Int
  key       String
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?
  company   Company  @relation(fields: [companyId], references: [id])

  @@unique([companyId, key])
}

/// Rounding rule for currency decimal calculations.
enum RoundingRule {
  ROUND_HALF_UP
  ROUND_HALF_DOWN
  ROUND_HALF_EVEN
  TRUNCATE
}

/// Source of an exchange rate.
enum RateSource {
  MANUAL
  AUTO_FETCH
}

/// Managed system currency per company — replaces the hardcoded Currency enum.
model SystemCurrency {
  id            String       @id @default(uuid())
  companyId     Int
  code          String       // e.g. "ETB", "USD"
  name          String       // e.g. "Ethiopian Birr", "US Dollar"
  symbol        String       // e.g. "Br", "$"
  decimalPlaces Int          @default(2)
  roundingRule  RoundingRule @default(ROUND_HALF_UP)
  isBase        Boolean      @default(false)
  isActive      Boolean      @default(true)
  autoFetchRate Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  company           Company        @relation(fields: [companyId], references: [id])
  companyBaseFor    Company?       @relation("BaseCurrency")  // The company that uses this as base currency
  ratesFrom         CurrencyRate[] @relation("CurrencyRateCurrency")
  ratesTo           CurrencyRate[] @relation("CurrencyRateCurrencyTo")

  @@unique([companyId, code])
  @@index([companyId, isActive])
}

model CurrencyRate {
  id             String      @id @default(uuid())
  companyId      Int
  fromCurrencyId String      // FK to SystemCurrency.id
  toCurrencyId   String      // FK to SystemCurrency.id
  rate           Decimal     @db.Decimal(15, 6)
  source         RateSource  @default(MANUAL)
  overrideReason String?
  effectiveDate  DateTime
  createdAt      DateTime    @default(now())

  company       Company        @relation(fields: [companyId], references: [id])
  fromCurrency  SystemCurrency @relation("CurrencyRateCurrency", fields: [fromCurrencyId], references: [id])
  toCurrency    SystemCurrency @relation("CurrencyRateCurrencyTo", fields: [toCurrencyId], references: [id])

  @@unique([companyId, fromCurrencyId, toCurrencyId, effectiveDate])
  @@index([companyId, effectiveDate])
}

model PayslipNotificationSettings {
  id               String          @id @default(uuid())
  companyId        Int             @unique
  emailNotifications Boolean       @default(true)
  smsNotifications  Boolean         @default(false)
  pushNotifications Boolean        @default(false)
  inAppNotifications Boolean       @default(false)
  digestFrequency   DigestFrequency @default(WEEKLY)
  payslipFormat     PayslipFormat  @default(PDF)
  emailTemplate     String?
  deliveryTriggers String?         // JSON array of DeliveryTrigger values, e.g. ["PAYSLIP_GENERATED", "MONTHLY_DIGEST"]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  company           Company         @relation(fields: [companyId], references: [id])
}

model PayFrequency {
  id                       String            @id @default(uuid())
  companyId                Int
  name                     String
  frequency                PayrollCycle
  periodsPerYear           Int
  isActive                 Boolean           @default(true)

  // Pay day rules
  payDayRule               PayDayRule?
  fixedPayDate             Int?              // e.g. 28 (day of month)
  offsetDays               Int?              // e.g. 3 (days after period closes)
  weekendRollover          WeekendRollover?
  holidayRollover          WeekendRollover?

  // Employee group assignment
  applicableEmployeeGroup  String?
  autoGeneratePeriods      Boolean           @default(true)

  // Daily-pay specifics
  dailyRateBasis           DailyRateBasis?
  workingDaysPerYear       Int?
  minimumPayableDays       Int?
  overtimeEligible         Boolean           @default(true)

  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
  company                  Company           @relation(fields: [companyId], references: [id])

  @@index([companyId, isActive])
}

model FiscalYear {
  id             String          @id @default(uuid())
  companyId      Int
  name           String
  startDate      DateTime
  endDate        DateTime
  status         FiscalStatus    @default(DRAFT)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  company        Company         @relation(fields: [companyId], references: [id])
  payrollPeriods PayrollPeriod[]

  @@index([companyId, isActive])
}

model PayrollPeriod {
  id                String              @id @default(uuid())
  companyId         Int
  fiscalYearId      String?
  name              String?
  cycle             PayrollCycle
  startDate         DateTime
  endDate           DateTime
  dateOfPayment     DateTime?
  status            PayrollPeriodStatus @default(DRAFT)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  attendanceImports AttendanceImport[]
  ercaSubmissions   ErcaSubmission[]
  leaveDeductions   LeaveDeduction[]
  leaveSyncLogs     LeaveSyncLog[]
  okrSyncLogs       OkrSyncLog[]
  payrollLeaveItems PayrollLeaveItem[]
  batches           PayrollBatch[]
  batchEmployees    PayrollBatchEmployee[]
  company           Company             @relation(fields: [companyId], references: [id])
  fiscalYear        FiscalYear?         @relation(fields: [fiscalYearId], references: [id])
  payrollRuns       PayrollRun[]
  reports           ReportExport[]
  statutoryReports  StatutoryReport[]

  @@unique([companyId, startDate, endDate, cycle])
  @@index([companyId, status])
}

model PayrollRun {
  id                  String             @id @default(uuid())
  payrollPeriodId     String
  payrollBatchId      String?
  status              PayrollStatus      @default(DRAFT)
  totalGross          Decimal            @default(0) @db.Decimal(15, 2)
  totalNet            Decimal            @default(0) @db.Decimal(15, 2)
  totalTax            Decimal            @default(0) @db.Decimal(15, 2)
  totalPension        Decimal            @default(0) @db.Decimal(15, 2)
  totalBonus          Decimal            @default(0) @db.Decimal(15, 2)
  totalOvertime       Decimal            @default(0) @db.Decimal(15, 2)
  totalCostToCompany  Decimal            @default(0) @db.Decimal(15, 2)
  employeeCount       Int                @default(0)
  monthlyWorkdays     Int                @default(30)
  processedAt         DateTime?
  finalizedAt         DateTime?
  createdBy           Int
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  approvalRequests    ApprovalRequest[]
  bankExportJobs      BankExportJob[]
  manualAdjustments   ManualAdjustment[]
  paymentFiles        PaymentFile[]
  payrollPeriod       PayrollPeriod      @relation(fields: [payrollPeriodId], references: [id])
  payrollBatch        PayrollBatch?      @relation(fields: [payrollBatchId], references: [id])
  payrollRunItems     PayrollRunItem[]

  @@index([payrollBatchId])
}

model PayrollRunItem {
  id                      String                   @id @default(uuid())
  payrollRunId            String
  employeeId              String
  workDays                Decimal                  @db.Decimal(5, 2)
  basicSalary             Decimal                  @db.Decimal(15, 2)
  proratedSalary          Decimal                  @db.Decimal(15, 2)
  grossTaxableIncome      Decimal                  @db.Decimal(15, 2)
  grossSalary             Decimal                  @db.Decimal(15, 2)
  costToCompany           Decimal                  @default(0) @db.Decimal(15, 2)
  totalDeductions         Decimal                  @db.Decimal(15, 2)
  netSalary               Decimal                  @db.Decimal(15, 2)
  currency                Currency                 @default(ETB)
  isMidMonthHire          Boolean                  @default(false)
  deductionCapBreached    Boolean                  @default(false)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  payrollAllowances       PayrollAllowance[]
  payrollBonuses          PayrollBonus[]
  payrollDeductions       PayrollDeduction[]
  payrollEarnings         PayrollEarning[]
  payrollLeaveItems       PayrollLeaveItem[]
  payrollOverrideRequests PayrollOverrideRequest[]
  payrollOvertime         PayrollOvertime[]
  payrollPension          PayrollPension?
  payrollProration        PayrollProration?
  employee                Employee                 @relation(fields: [employeeId], references: [id])
  payrollRun              PayrollRun               @relation(fields: [payrollRunId], references: [id])
  payrollTax              PayrollTax?
  payslip                 Payslip?

  @@unique([payrollRunId, employeeId])
  @@index([payrollRunId])
  @@index([employeeId])
}

model PayrollEarning {
  id               String         @id @default(uuid())
  payrollRunItemId String
  earningType      EarningType
  label            String
